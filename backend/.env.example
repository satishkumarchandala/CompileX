# Example environment variables for production
# Copy this to .env and fill in your actual values

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas → Connect → Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/compiler_gamified?retryWrites=true&w=majority

# Database name
MONGODB_DB=compiler_gamified

# JWT Secret - Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-random-secret-here

# Allow admin registration (set to false in production)
ALLOW_ADMIN_REG=true

# Port (Render uses 10000 by default)
PORT=5000

# ── Email / Gmail SMTP ────────────────────────────────────────────────────────
# Used to send notifications when a student is assigned to an instructor.
# IMPORTANT: SMTP_PASS must be a Gmail App Password, NOT your normal Gmail password.
# To create an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already done
#   3. Search for "App Passwords" and generate one for "Mail"
#   4. Paste the 16-character app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
FROM_EMAIL=your-gmail-address@gmail.com
